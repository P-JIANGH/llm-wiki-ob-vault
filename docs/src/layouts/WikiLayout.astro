---
// WikiLayout.astro — wraps all wiki pages
import type { VaultEntry } from '../lib/vault';
import { buildSidebar, loadAllPages } from '../lib/vault';
import '../styles/global.css';

interface Props {
  title?: string;
  currentSlug?: string;
}

const { title = 'LLM Wiki', currentSlug = '' } = Astro.props;
const allPages = loadAllPages();
const sidebar = buildSidebar(allPages);
const fullTitle = title === 'LLM Wiki' ? 'LLM Wiki' : `${title} — LLM Wiki`;
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content="LLM Wiki — Knowledge Base" />
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📚</text></svg>" />
</head>
<body>
  <!-- Header -->
  <header class="site-header">
    <button class="menu-btn" id="menuToggle" style="display:none" aria-label="Toggle menu">☰</button>
    <a href="/" class="site-title">📚 <span>LLM</span> Wiki</a>
    <nav class="site-meta">
      <a href="https://gitcode.com/jingh_hnr/llm-wiki-ob-vault" target="_blank" rel="noopener">源码</a>
      <span style="margin-left:1rem">{allPages.length} 页面</span>
    </nav>
  </header>

  <div class="layout">
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <a href="/" class="sidebar-item" class:list={[{ active: currentSlug === '' || currentSlug === 'index' }]}>🏠 首页</a>

      {sidebar.map(section => (
        section.id === 'raw' ? null :
        <>
          <div class="sidebar-section-title">{section.label}</div>
          {section.entries.map(entry => (
            <a
              href={`/${entry.slug}`}
              class="sidebar-item"
              class:list={[{ active: currentSlug === entry.slug }]}
            >
              {entry.title}
            </a>
          ))}
        </>
      ))}

      <div class="sidebar-section-title">原始资料 Raw</div>
      {allPages.filter(p => p.section === 'raw').map(entry => (
        <a
          href={`/${entry.slug}`}
          class="sidebar-item"
          class:list={[{ active: currentSlug === entry.slug }]}
        >
          {entry.title}
        </a>
      ))}

      <div class="sidebar-section-title" style="margin-top:1.5rem">其他</div>
      <a href="/SCHEMA" class="sidebar-item" class:list={[{ active: currentSlug === 'SCHEMA' }]}>Schema</a>
      <a href="/log" class="sidebar-item" class:list={[{ active: currentSlug === 'log' }]}>Log</a>
      <a href="/open-source-games-learning-checklist" class="sidebar-item" class:list={[{ active: currentSlug === 'open-source-games-learning-checklist' }]}>🎮 开源游戏学习清单</a>
    </aside>

    <!-- Main -->
    <main class="main-content">
      <slot />
    </main>
  </div>

  <script>
    // Mobile menu toggle
    const btn = document.getElementById('menuToggle');
    const sidebar = document.getElementById('sidebar');
    if (btn && sidebar) {
      btn.addEventListener('click', () => sidebar.classList.toggle('open'));
      document.addEventListener('click', (e) => {
        if (!sidebar.contains(e.target as Node) && !btn.contains(e.target as Node)) {
          sidebar.classList.remove('open');
        }
      });
    }
    // Highlight active sidebar item
    const currentLinks = document.querySelectorAll('.sidebar-item');
    currentLinks.forEach(link => {
      if ((link as HTMLAnchorElement).getAttribute('href') === window.location.pathname) {
        link.classList.add('active');
      }
    });
    // Show mobile menu button on small screens
    if (window.matchMedia('(max-width: 768px)').matches) {
      const mb = document.getElementById('menuToggle') as HTMLElement;
      if (mb) mb.style.display = 'flex';
    }
  </script>
</body>
</html>
